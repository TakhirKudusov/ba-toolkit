# Astro / Node build artefacts — never committed.
dist/
.astro/
node_modules/
.env
.env.production
.DS_Store

# Synced markdown content — generated by scripts/sync-content.mjs at build
# time from the repo root (ROADMAP.md, COMMANDS.md, CHANGELOG.md, docs/*.md).
# Hand-written pages (index.mdx, getting-started.md) are committed directly.
src/content/docs/usage.md
src/content/docs/commands.md
src/content/docs/faq.md
src/content/docs/domains.md
src/content/docs/troubleshooting.md
src/content/docs/roadmap.md
src/content/docs/changelog.md
